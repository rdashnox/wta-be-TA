{
  "name": "wta-be",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "seed:users": "cross-env NODE_ENV=development node seeder/usersSeeder.js",
    "seed:rooms": "cross-env NODE_ENV=development node seeder/roomSeeder.js",
    "seed:bookings": "cross-env NODE_ENV=development node seeder/bookingSeeder.js",
    "seed:all": "npm run seed:users && npm run seed:rooms && npm run seed:bookings",
    "seed:dev": "npm run seed:users && npm run seed:rooms && npm run seed:bookings",
    "seed:clean": "cross-env NODE_ENV=development node seeder/deleteResources.js && npm run seed:dev",
    "dev": "cross-env NODE_ENV=development nodemon ./bin/www",
    "start": "NODE_ENV=production node ./bin/www",
    "test": "cross-env NODE_ENV=test jest --runInBand --detectOpenHandles",
    "test:watch": "cross-env NODE_ENV=test jest --watch",
    "test:coverage": "cross-env NODE_ENV=test jest --coverage",
    "test:unit": "cross-env NODE_ENV=test jest --runInBand --detectOpenHandles tests/unit",
    "test:integration": "cross-env NODE_ENV=test --runInBand --detectOpenHandles jest tests/integration",
    "test:booking": "cross-env NODE_ENV=test jest --runInBand --detectOpenHandles tests/unit/bookingService.test.js",
    "test:pricing": "cross-env NODE_ENV=test jest --runInBand --detectOpenHandles tests/unit/pricingService.test.js",
    "test:booking:int": "cross-env NODE_ENV=test jest --runInBand --detectOpenHandles tests/integration/booking.test.js",
    "test:contact": "cross-env NODE_ENV=test jest --runInBand --detectOpenHandles tests/unit/contactController.test.js",
    "test:subscription": "cross-env NODE_ENV=test jest --runInBand --detectOpenHandles tests/unit/subscriptionController.test.js",
    "test:auth": "cross-env NODE_ENV=test jest --runInBand --detectOpenHandles tests/unit/authController.test.js",
    "test:auth:int": "cross-env NODE_ENV=test jest --runInBand --detectOpenHandles tests/integration/auth.test.js",
    "test:room": "cross-env NODE_ENV=test jest --runInBand --detectOpenHandles tests/unit/roomController.test.js",
    "test:unit:watch": "cross-env NODE_ENV=test jest tests/unit --watch",
    "test:integration:watch": "cross-env NODE_ENV=test jest tests/integration --watch",
    "seed:prod": "npm run seed:users && npm run seed:rooms && npm run seed:bookings",
    "deploy:seed": "npm run seed:prod"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "apicache": "^1.6.3",
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.9.0",
    "compression": "^1.8.1",
    "cookie-parser": "~1.4.4",
    "cors": "^2.8.5",
    "cross-env": "^10.1.0",
    "debug": "~2.6.9",
    "dompurify": "^3.3.2",
    "dotenv": "^17.2.3",
    "express": "^4.22.1",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^8.3.0",
    "helmet": "^8.1.0",
    "http-errors": "^2.0.1",
    "joi": "^18.0.2",
    "jsdom": "^28.1.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.1.5",
    "mongoose-to-swagger": "^1.5.1",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-jwt": "^4.0.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "winston": "^3.19.0",
    "xss-clean": "^0.1.4"
  },
  "devDependencies": {
    "@shelf/jest-mongodb": "^6.0.2",
    "@types/supertest": "^7.2.0",
    "jest": "^30.3.0",
    "mongodb-memory-server": "^11.0.1",
    "nodemon": "^3.1.11",
    "supertest": "^7.2.2"
  },
  "jest": {
    "testEnvironment": "node",
    "setupFilesAfterEnv": [
      "<rootDir>/tests/testSetup.js"
    ],
    "testMatch": [
      "**/__tests__/**/*.js",
      "**/?(*.)+(spec|test).js"
    ],
    "collectCoverageFrom": [
      "controllers/**/*.js",
      "services/**/*.js",
      "routes/**/*.js"
    ],
    "forceExit": true,
    "testTimeout": 30000
  }
}
